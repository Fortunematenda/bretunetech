generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            Role             @default(CUSTOMER)
  customRoleId    String?
  customRole      CustomRole?      @relation(fields: [customRoleId], references: [id])
  avatarUrl       String?
  isDeleted       Boolean          @default(false)
  isVerified      Boolean          @default(false)
  emailOtp        String?
  emailOtpExpiry  DateTime?
  acceptedTerms   Boolean          @default(false)
  termsAcceptedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  addresses       Address[]
  cart            Cart?
  invoices        Invoice[]
  notifications   Notification[]
  orders          Order[]
  returnRequests  ReturnRequest[]
  reviews         Review[]
  serviceBookings ServiceBooking[]
  vendor          Vendor?          @relation("VendorUser")
  wishlist        Wishlist[]

  @@index([email])
  @@index([role])
  @@index([customRoleId])
  @@map("users")
}

model Address {
  id               String  @id @default(uuid())
  userId           String
  label            String?
  street           String
  suburb           String?
  city             String
  province         String
  postalCode       String
  country          String  @default("South Africa")
  formattedAddress String?
  placeId          String?
  latitude         Float?
  longitude        Float?
  addressVerified  Boolean @default(false)
  isDefault        Boolean @default(false)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@map("addresses")
}

model Vendor {
  id             String    @id @default(uuid())
  userId         String    @unique
  businessName   String
  slug           String    @unique
  description    String?
  logoUrl        String?
  commissionRate Float     @default(0.10)
  isApproved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  products       Product[]
  user           User      @relation("VendorUser", fields: [userId], references: [id])

  @@map("vendors")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]

  @@map("categories")
}

model Product {
  id                String                 @id @default(uuid())
  name              String
  slug              String                 @unique
  description       String
  categoryId        String
  condition         ProductCondition       @default(NEW)
  costPrice         Float
  sellingPrice      Float
  originalPrice     Float?
  discountExpiresAt DateTime?
  stockQuantity     Int                    @default(0)
  lowStockThreshold Int                    @default(5)
  supplierName      String?
  sku               String?                @unique
  isFeatured        Boolean                @default(false)
  isActive          Boolean                @default(true)
  isDeleted         Boolean                @default(false)
  vendorId          String?
  brandId           String?
  manualUrl         String?
  additionalInfo    String?
  metaTitle         String?
  metaDescription   String?
  focusKeyword      String?
  seoScore          Int?
  seoStatus         String?
  averageRating     Float                  @default(0)
  reviewCount       Int                    @default(0)
  shippingDays      Int                    @default(3)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  stockCpt          Int                    @default(0)
  stockDbn          Int                    @default(0)
  stockJhb          Int                    @default(0)
  bundleItems       BundleItem[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  images            ProductImage[]
  specifications    ProductSpecification[]
  tags              ProductTag[]
  variants          ProductVariant[]
  brand             Brand?                 @relation(fields: [brandId], references: [id])
  category          Category               @relation(fields: [categoryId], references: [id])
  vendor            Vendor?                @relation(fields: [vendorId], references: [id])
  returnItems       ReturnItem[]
  reviews           Review[]
  stockHistory      StockHistory[]
  wishlistItems     Wishlist[]
  relatedProducts   RelatedProduct[]
  schemaJsonLd      String?                @db.Text
  documents         ProductDocument[]

  @@index([categoryId])
  @@index([sellingPrice])
  @@index([condition])
  @@index([isFeatured])
  @@index([isActive, isDeleted])
  @@index([name])
  @@index([vendorId])
  @@index([brandId])
  @@index([createdAt])
  @@map("products")
}

model ProductDocument {
  id           String   @id @default(uuid())
  productId    String
  url          String
  publicId     String?
  name         String
  type         String   @default("pdf")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_documents")
}

model RelatedProduct {
  id               String   @id @default(uuid())
  productId        String
  relatedProductId String
  score            Int      @default(0)
  createdAt        DateTime @default(now())
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@index([relatedProductId])
  @@map("related_products")
}

model ProductSpecification {
  id        String   @id @default(uuid())
  productId String
  key       String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specifications")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductTag {
  id        String  @id @default(uuid())
  productId String
  tag       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("product_tags")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, productId])
  @@unique([userId, productId], map: "unique_user_product_wishlist")
  @@index([userId])
  @@index([productId])
  @@index([productId], map: "idx_wishlists_product")
  @@index([userId], map: "idx_wishlists_user")
  @@map("wishlists")
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  productId  String
  rating     Int      @default(5)
  title      String?
  comment    String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([isApproved])
  @@index([userId])
  @@map("reviews")
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String
  name          String
  value         String
  priceAdjust   Float   @default(0)
  stockQuantity Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@map("brands")
}

model Ad {
  id                    String   @id @default(uuid())
  title                 String
  subtitle              String?
  badge                 String?
  backgroundColor       String
  type                  String
  cta                   String?
  href                  String?
  price                 String?
  period                String?
  phone                 String?
  features              Json?
  services              Json?
  extras                Json?
  imageUrl              String?
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  heroTitle             String?
  heroSubtitle          String?
  heroSlides            Json?
  heroCtaText           String?
  heroCtaLink           String?
  heroQuoteText         String?
  heroQuoteLink         String?
  descriptionColor      String?
  subtitleColor         String?
  textColor             String?
  ctaBgColor            String?
  ctaTextColor          String?
  secondaryBgColor      String?
  secondaryTextColor    String?
  cardAccentColor       String?
  cardBgColor           String?
  cardBtnBgColor        String?
  cardBtnTextColor      String?
  cardNameColor         String?
  cardPriceColor        String?
  cardBorderColor       String?
  eyebrowBgColor        String?
  eyebrowBorderColor    String?
  eyebrowTextColor      String?
  slideBadgeBgColor     String?
  slideBadgeBorderColor String?
  slideBadgeTextColor   String?
  heroTemplate          String?

  @@index([isActive])
  @@index([sortOrder])
  @@map("ads")
}

model MarketingAd {
  id                    String   @id @default(uuid())
  title                 String
  template              String
  productId             String?
  productName           String
  productImage          String?
  price                 String?
  salePrice             String?
  brand                 String?
  description           String?
  headline              String
  subheading            String?
  benefits              Json?
  pricing               Json?
  branding              Json?
  exportFormat          String   @default("facebook_post")
  generatedImageUrl     String?
  generatedThumbnailUrl String?
  downloadCount         Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([template])
  @@index([isActive])
  @@index([createdAt])
  @@map("marketing_ads")
}

model Bundle {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String
  bundlePrice Float
  imageUrl    String?
  isFeatured  Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       BundleItem[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("bundles")
}

model BundleItem {
  id        String  @id @default(uuid())
  bundleId  String
  productId String
  quantity  Int     @default(1)
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
  @@map("bundle_items")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id                String   @id @default(uuid())
  cartId            String
  productId         String?
  bundleId          String?
  quantity          Int      @default(1)
  warehouseLocation String?
  bundle            Bundle?  @relation(fields: [bundleId], references: [id])
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Order {
  id                 String          @id @default(uuid())
  orderNumber        String          @unique
  userId             String
  addressId          String?
  status             OrderStatus     @default(PENDING)
  paymentMethod      PaymentMethod   @default(EFT)
  paymentRef         String?
  idempotencyKey     String?         @unique
  subtotal           Float
  shippingCost       Float           @default(0)
  totalPrice         Float
  notes              String?
  deletedAt          DateTime?
  deletedByAdminId   String?
  deletedByAdminName String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  invoice            Invoice?
  items              OrderItem[]
  address            Address?        @relation(fields: [addressId], references: [id])
  user               User            @relation(fields: [userId], references: [id])
  returnRequests     ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@map("orders")
}

model OrderItem {
  id                String       @id @default(uuid())
  orderId           String
  productId         String?
  bundleId          String?
  name              String
  price             Float
  quantity          Int
  warehouseLocation String?
  bundle            Bundle?      @relation(fields: [bundleId], references: [id])
  order             Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?     @relation(fields: [productId], references: [id])
  returnItems       ReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model StockHistory {
  id             String          @id @default(uuid())
  productId      String
  changeType     StockChangeType
  quantityChange Int
  previousQty    Int
  newQty         Int
  orderId        String?
  note           String?
  createdAt      DateTime        @default(now())
  product        Product         @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([changeType])
  @@index([createdAt])
  @@map("stock_history")
}

model ServiceBooking {
  id             String             @id @default(uuid())
  bookingNumber  String             @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  company        String?
  serviceType    BookingServiceType
  status         BookingStatus      @default(PENDING)
  address        String
  city           String
  province       String
  postalCode     String
  preferredDate  DateTime?
  scheduledDate  DateTime?
  scheduledTime  String?
  technicianId   String?
  technicianName String?
  description    String?
  internalNotes  String?
  estimatedCost  Float?
  finalCost      Float?
  userId         String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  emailCount     Int                @default(0)
  emailSentAt    DateTime?
  user           User?              @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([serviceType])
  @@index([scheduledDate])
  @@index([userId])
  @@map("service_bookings")
}

model Invoice {
  id              String         @id @default(uuid())
  invoiceNumber   String         @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  businessName    String         @default("Bretune Technologies")
  businessReg     String?
  vatNumber       String?
  subtotal        Float
  vatAmount       Float          @default(0)
  total           Float
  amountPaid      Float          @default(0)
  status          InvoiceStatus  @default(DRAFT)
  dueDate         DateTime
  paidAt          DateTime?
  paymentMethod   PaymentMethod?
  paymentRef      String?
  orderId         String?        @unique
  userId          String?
  items           Json
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  order           Order?         @relation(fields: [orderId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@index([userId])
  @@map("invoices")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  group       String   @default("general")
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

model BusinessSettings {
  id                 String   @id @default(uuid())
  name               String   @default("Bretune Technologies")
  legalName          String   @default("Bretune Technologies (Pty) Ltd")
  registrationNumber String   @default("2025/545182/07")
  taxNumber          String   @default("9276141273")
  website            String   @default("https://bretunetech.com")
  email              String   @default("sales@bretune.co.za")
  supportEmail       String   @default("support@bretunetech.com")
  phone              String   @default("+27 61 268 5933")
  address            String   @default("123 Main Road, Cape Town, 8001, South Africa")
  country            String   @default("South Africa")
  businessType       String   @default("Technology Ecommerce & Solutions Provider")
  bankName           String?
  accountNumber      String?
  accountHolder      String?
  branchCode         String?
  accountType        String   @default("Current")
  vatIncluded        Boolean  @default(true)
  vatRate            Float    @default(15)
  showLegalInfo      Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  maintenanceMessage    String?
  googleSiteVerification String?
  bingSiteVerification   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("business_settings")
}

model Enquiry {
  id        String        @id @default(uuid())
  userId    String?
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  budget    String?
  urgency   String?
  message   String
  status    EnquiryStatus @default(NEW)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("enquiries")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model ReturnRequest {
  id                  String                @id @default(uuid())
  returnNumber        String                @unique
  orderId             String
  customerId          String
  status              ReturnStatus          @default(REQUESTED)
  requestedResolution ReturnResolution
  customerReason      String
  customerComment     String?
  adminNote           String?
  customerVisibleNote String?
  totalReturnValue    Float                 @default(0)
  completedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  attachments         ReturnAttachment[]
  items               ReturnItem[]
  customer            User                  @relation(fields: [customerId], references: [id])
  order               Order                 @relation(fields: [orderId], references: [id])
  statusHistory       ReturnStatusHistory[]

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("return_requests")
}

model ReturnItem {
  id                String        @id @default(uuid())
  returnRequestId   String
  orderItemId       String
  productId         String?
  quantity          Int
  unitPrice         Float
  total             Float
  reason            String?
  conditionReceived String?
  inspectionNote    String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  orderItem         OrderItem     @relation(fields: [orderItemId], references: [id])
  product           Product?      @relation(fields: [productId], references: [id])
  returnRequest     ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@index([orderItemId])
  @@map("return_items")
}

model ReturnAttachment {
  id              String        @id @default(uuid())
  returnRequestId String
  fileUrl         String
  fileName        String
  fileType        String?
  uploadedBy      String?
  createdAt       DateTime      @default(now())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@map("return_attachments")
}

model ReturnStatusHistory {
  id               String        @id @default(uuid())
  returnRequestId  String
  oldStatus        ReturnStatus
  newStatus        ReturnStatus
  note             String?
  changedByAdminId String?
  createdAt        DateTime      @default(now())
  returnRequest    ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId])
  @@map("return_status_history")
}

model Supplier {
  id            String   @id @default(uuid())
  name          String   @unique
  contactPerson String?
  email         String?
  phone         String?
  website       String?
  address       String?
  city          String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("suppliers")
}

model WebsiteVisit {
  id         String   @id @default(uuid())
  visitorId  String
  sessionId  String
  ipHash     String?
  userAgent  String?
  pageUrl    String
  pageTitle  String?
  referrer   String?
  deviceType String?
  browser    String?
  country    String?
  city       String?
  productId  String?
  createdAt  DateTime @default(now())
  ipAddress  String?

  @@index([createdAt])
  @@index([pageUrl])
  @@index([productId])
  @@index([sessionId])
  @@index([visitorId])
  @@map("website_visits")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  category        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  customRolePermissions CustomRolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@index([permissionId])
  @@map("role_permissions")
}

model CustomRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  permissions CustomRolePermission[]

  @@map("custom_roles")
}

model CustomRolePermission {
  id           String      @id @default(uuid())
  customRoleId String
  permissionId String
  createdAt    DateTime    @default(now())
  customRole   CustomRole  @relation(fields: [customRoleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([customRoleId, permissionId])
  @@index([customRoleId])
  @@index([permissionId])
  @@map("custom_role_permissions")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
  VENDOR
  STAFF
}

enum ProductCondition {
  NEW
  REFURBISHED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  EFT
  PAYFAST
  OZOW
  WHATSAPP
  YOCO
}

enum StockChangeType {
  SALE
  RETURN
  RESTOCK
  ADJUSTMENT
  BUNDLE_SALE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingServiceType {
  WIFI_INSTALLATION
  FIBRE_INSTALLATION
  CCTV_SETUP
  MIKROTIK_CONFIGURATION
  REMOTE_SUPPORT
  NETWORK_TROUBLESHOOTING
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum EnquiryStatus {
  NEW
  READ
  REPLIED
  CLOSED
}

enum NotificationType {
  ORDER_STATUS
  PROMOTION
  ACCOUNT
  GENERAL
}

enum ReturnStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  AWAITING_CUSTOMER_RETURN
  RECEIVED
  INSPECTING
  REFUND_APPROVED
  REPLACEMENT_SENT
  COMPLETED
  CANCELLED
}

enum ReturnResolution {
  REFUND
  REPLACEMENT
  EXCHANGE
  STORE_CREDIT
}

model SeoUrlInspection {
  id               String    @id @default(uuid())
  url              String    @unique
  pageType         String    @default("page")
  status           String?
  coverageState    String?
  lastCrawlTime    DateTime?
  googleCanonical  String?
  userCanonical    String?
  robotsState      String?
  pageFetchState   String?
  mobileUsability  String?
  richResults      String?
  seoScore         Int?
  issue            String?
  recommendedFix   String?
  notes            String?
  checkedAt        DateTime  @default(now())
  followUpAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime @updatedAt

  @@index([coverageState])
  @@index([checkedAt])
  @@index([followUpAt])
  @@index([pageType])
  @@map("seo_url_inspections")
}
