generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String
  firstName       String
  lastName        String
  phone           String?
  role            Role             @default(CUSTOMER)
  avatarUrl       String?
  isDeleted       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  addresses       Address[]
  cart            Cart?
  invoices        Invoice[]
  orders          Order[]
  serviceBookings ServiceBooking[]
  vendor          Vendor?          @relation("VendorUser")
  wishlist        Wishlist[]
  reviews         Review[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  label      String?
  street     String
  city       String
  province   String
  postalCode String
  country    String  @default("South Africa")
  isDefault  Boolean @default(false)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

model Vendor {
  id             String    @id @default(uuid())
  userId         String    @unique
  businessName   String
  slug           String    @unique
  description    String?
  logoUrl        String?
  commissionRate Float     @default(0.10)
  isApproved     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  products       Product[]
  user           User      @relation("VendorUser", fields: [userId], references: [id])

  @@map("vendors")
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]

  @@map("categories")
}

model Product {
  id                String           @id @default(uuid())
  name              String
  slug              String           @unique
  description       String
  categoryId        String
  condition         ProductCondition @default(NEW)
  costPrice         Float
  sellingPrice      Float
  originalPrice     Float?
  discountExpiresAt DateTime?
  stockQuantity     Int              @default(0)
  stockCpt          Int              @default(0)
  stockJhb          Int              @default(0)
  stockDbn          Int              @default(0)
  lowStockThreshold Int              @default(5)
  supplierName      String?
  sku               String?          @unique
  isFeatured        Boolean          @default(false)
  isActive          Boolean          @default(true)
  isDeleted         Boolean          @default(false)
  vendorId          String?
  manualUrl         String?
  additionalInfo    String?
  averageRating     Float            @default(0)
  reviewCount       Int              @default(0)
  shippingDays      Int              @default(3)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  bundleItems       BundleItem[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  images            ProductImage[]
  tags              ProductTag[]
  variants          ProductVariant[]
  specifications    ProductSpecification[]
  category          Category         @relation(fields: [categoryId], references: [id])
  vendor            Vendor?          @relation(fields: [vendorId], references: [id])
  stockHistory      StockHistory[]
  wishlistItems     Wishlist[]
  reviews           Review[]

  @@index([categoryId])
  @@index([sellingPrice])
  @@index([condition])
  @@index([isFeatured])
  @@index([isActive, isDeleted])
  @@index([name])
  @@index([vendorId])
  @@index([createdAt])
  @@map("products")
}

model ProductSpecification {
  id        String   @id @default(uuid())
  productId String
  key       String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specifications")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductTag {
  id        String  @id @default(uuid())
  productId String
  tag       String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tag])
  @@map("product_tags")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, productId])
  @@unique([userId, productId], map: "unique_user_product_wishlist")
  @@index([userId])
  @@index([productId])
  @@index([productId], map: "idx_wishlists_product")
  @@index([userId], map: "idx_wishlists_user")
  @@map("wishlists")
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int      @default(5)
  title     String?
  comment   String?
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([isApproved])
  @@index([userId])
  @@map("reviews")
}

model ProductVariant {
  id            String  @id @default(uuid())
  productId     String
  name          String
  value         String
  priceAdjust   Float   @default(0)
  stockQuantity Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  logoUrl     String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@map("brands")
}

model Ad {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  badge       String?
  backgroundColor String
  type        String
  cta         String?
  href        String?
  price       String?
  period      String?
  phone       String?
  features    Json?
  services    Json?
  extras      Json?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // Hero banner specific fields
  heroTitle   String?
  heroSubtitle String?
  heroSlides  Json?
  heroCtaText String?
  heroCtaLink String?
  heroQuoteText String?
  heroQuoteLink String?
  textColor        String?
  subtitleColor    String?
  descriptionColor String?
  ctaBgColor          String?
  ctaTextColor        String?
  secondaryBgColor    String?
  secondaryTextColor  String?
  cardBgColor         String?
  cardAccentColor     String?
  cardNameColor       String?
  cardPriceColor      String?
  cardBtnBgColor      String?
  cardBtnTextColor    String?
  cardBorderColor       String?
  eyebrowBgColor        String?
  eyebrowTextColor      String?
  eyebrowBorderColor    String?
  slideBadgeBgColor     String?
  slideBadgeTextColor   String?
  slideBadgeBorderColor String?
  heroTemplate          String?

  @@index([isActive])
  @@index([sortOrder])
  @@map("ads")
}

model Bundle {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  description String
  bundlePrice Float
  imageUrl    String?
  isFeatured  Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       BundleItem[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@map("bundles")
}

model BundleItem {
  id        String  @id @default(uuid())
  bundleId  String
  productId String
  quantity  Int     @default(1)
  bundle    Bundle  @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([bundleId, productId])
  @@map("bundle_items")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id                String   @id @default(uuid())
  cartId            String
  productId         String?
  bundleId          String?
  quantity          Int      @default(1)
  warehouseLocation String?
  bundle            Bundle?  @relation(fields: [bundleId], references: [id])
  cart              Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@map("cart_items")
}

model Order {
  id             String        @id @default(uuid())
  orderNumber    String        @unique
  userId         String
  addressId      String?
  status         OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod @default(EFT)
  paymentRef     String?
  idempotencyKey String?       @unique
  subtotal       Float
  shippingCost   Float         @default(0)
  totalPrice     Float
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoice        Invoice?
  items          OrderItem[]
  address        Address?      @relation(fields: [addressId], references: [id])
  user           User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@map("orders")
}

model OrderItem {
  id                String   @id @default(uuid())
  orderId           String
  productId         String?
  bundleId          String?
  name              String
  price             Float
  quantity          Int
  warehouseLocation String?
  bundle            Bundle?  @relation(fields: [bundleId], references: [id])
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model StockHistory {
  id             String          @id @default(uuid())
  productId      String
  changeType     StockChangeType
  quantityChange Int
  previousQty    Int
  newQty         Int
  orderId        String?
  note           String?
  createdAt      DateTime        @default(now())
  product        Product         @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([changeType])
  @@index([createdAt])
  @@map("stock_history")
}

model ServiceBooking {
  id             String             @id @default(uuid())
  bookingNumber  String             @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  company        String?
  serviceType    BookingServiceType
  status         BookingStatus      @default(PENDING)
  address        String
  city           String
  province       String
  postalCode     String
  preferredDate  DateTime?
  scheduledDate  DateTime?
  scheduledTime  String?
  technicianId   String?
  technicianName String?
  description    String?
  internalNotes  String?
  estimatedCost  Float?
  finalCost      Float?
  emailSentAt    DateTime?
  emailCount     Int                @default(0)
  userId         String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User?              @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([serviceType])
  @@index([scheduledDate])
  @@index([userId])
  @@map("service_bookings")
}

model Invoice {
  id              String         @id @default(uuid())
  invoiceNumber   String         @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerAddress String?
  businessName    String         @default("Bretune Technologies")
  businessReg     String?
  vatNumber       String?
  subtotal        Float
  vatAmount       Float          @default(0)
  total           Float
  amountPaid      Float          @default(0)
  status          InvoiceStatus  @default(DRAFT)
  dueDate         DateTime
  paidAt          DateTime?
  paymentMethod   PaymentMethod?
  paymentRef      String?
  orderId         String?        @unique
  userId          String?
  items           Json
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  order           Order?         @relation(fields: [orderId], references: [id])
  user            User?          @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([dueDate])
  @@index([userId])
  @@map("invoices")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  group       String   @default("general")
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

enum Role {
  CUSTOMER
  ADMIN
  VENDOR
  STAFF
}

enum ProductCondition {
  NEW
  REFURBISHED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  EFT
  PAYFAST
  OZOW
  WHATSAPP
  YOCO
}

enum StockChangeType {
  SALE
  RETURN
  RESTOCK
  ADJUSTMENT
  BUNDLE_SALE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingServiceType {
  WIFI_INSTALLATION
  FIBRE_INSTALLATION
  CCTV_SETUP
  MIKROTIK_CONFIGURATION
  REMOTE_SUPPORT
  NETWORK_TROUBLESHOOTING
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Enquiry {
  id        String        @id @default(uuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  budget    String?
  urgency   String?
  message   String
  status    EnquiryStatus @default(NEW)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("enquiries")
}

enum EnquiryStatus {
  NEW
  READ
  REPLIED
  CLOSED
}
