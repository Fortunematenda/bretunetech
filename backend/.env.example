# ─── Database ─────────────────────────────────────────
DATABASE_URL="postgresql://bretunetech:CHANGE_ME@localhost:5432/bretunetech?schema=public"

# ─── Auth / JWT ───────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
DEFAULT_MARKUP_PERCENTAGE="25"

# ─── File Uploads (Cloudinary) ────────────────────────
# Required to re-host CSV-imported supplier images. If left blank, imported
# products are saved without an image (the supplier hot-link is never stored).
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ─── Payments (PayFast) ──────────────────────────────
PAYFAST_MERCHANT_ID=""
PAYFAST_MERCHANT_KEY=""
PAYFAST_PASSPHRASE=""
PAYFAST_SANDBOX="true"

# ─── Payments (Ozow) ─────────────────────────────────
OZOW_SITE_CODE=""
OZOW_PRIVATE_KEY=""
OZOW_API_KEY=""

# ─── Google Maps (Address Validation) ────────────────
# Server-side key for geocoding/address validation. Restrict by IP.
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── Google Search Console (SEO Indexing) ───────────────
# Service account used for URL Inspection API. Do NOT use the OAuth client secret.
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GSC_SITE_URL="https://www.example.com"
